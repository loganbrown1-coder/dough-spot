# Copy this file to .env.local and fill in the values from your Supabase
# project (Project Settings > API). Never commit .env.local - it's already
# gitignored.

# Project URL, e.g. https://abcdefghij.supabase.co
SUPABASE_URL=

# Project Settings > API > anon / public key. Safe to use in a browser, but
# here it's used server-side to create a client bound to the signed-in
# user's session, so Postgres row level security policies apply.
SUPABASE_ANON_KEY=

# Same two values again, but NEXT_PUBLIC_-prefixed so Next.js inlines them
# into the browser bundle - needed only by
# app/components/AuthCallbackClient.tsx, which reads the session tokens
# Supabase puts in the invite/recovery link's URL fragment (fragments
# never reach the server, so that one case has to run client-side). Not a
# new secret - same anon key as above, just exposed to the browser on
# purpose this time.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings > API > service_role key (NOT the anon/public key).
# This key bypasses row level security - it's only used for the two things
# that genuinely require it: the Supabase Auth admin API (inviting users)
# and writing uploaded photos to Storage. When deploying to Vercel, set
# this as an environment variable in the Vercel project settings, not in a
# committed file.
SUPABASE_SERVICE_ROLE_KEY=

# The URL this app is reachable at - used to build the link in invite
# emails (Authentication > URL Configuration > Redirect URLs in the
# Supabase dashboard must include `${SITE_URL}/auth/callback`). Use your
# Vercel URL once deployed.
SITE_URL=http://localhost:3000

# Any long random string - authorizes the scheduled retention purge job
# (see vercel.json + app/api/cron/purge-expired-captures). Vercel sends
# this automatically as `Authorization: Bearer $CRON_SECRET` on the cron
# request once it's set as an env var in your Vercel project; the route
# rejects every request until it's configured. Generate one with
# `openssl rand -hex 32`.
CRON_SECRET=
